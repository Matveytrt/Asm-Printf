    10                                  %macro PRINT_STR 2
    11                                      mov rax, 0x01
    12                                      mov rdi, 1
    13                                      mov rsi, %1 ;msg
    14                                      mov rdx, %2 ;len
    15                                      syscall
    16                                  %endmacro
